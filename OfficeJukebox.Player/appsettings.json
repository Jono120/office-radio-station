{
  "Api": {
    "NotifyBaseUrl": "http://localhost:5080"
  },
  "Security": {
    "InternalSharedSecret": "change-me-internal-secret"
  },
  "Storage": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=%LOCALAPPDATA%/OfficeJukebox/jukebox.db"
  },
  "Organization": {
    "Name": "Your Organization",
    "Domain": "YOURDOMAIN",
    "TimeZone": ""
  },
  "QueueRules": {
    "MaxTracksPerUser": 5,
    "DontRepeatHours": 4
  },
  "VetoRules": {
    "DailyLimit": 20
  },
  "SkipRules": {
    "MinimumVetoCount": 3
  },
  "MusicProviders": {
    "YouTube": {
      "Enabled": true,
      "ApiKey": ""
    },
    "Manual": {
      "Enabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Urls": "http://localhost:5050"
}
