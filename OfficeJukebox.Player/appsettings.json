{
  "Storage": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=%LOCALAPPDATA%/OfficeJukebox/jukebox.db"
  },
  "Organization": {
    "Name": "Your Organization",
    "Domain": "YOURDOMAIN"
  },
  "QueueRules": {
    "MaxTracksPerUser": 5,
    "DontRepeatHours": 4
  },
  "VetoRules": {
    "DailyLimit": 20
  },
  "SkipRules": {
    "MinimumVetoCount": 3
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "Urls": "http://localhost:5050"
}
